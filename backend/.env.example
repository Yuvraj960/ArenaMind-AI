# ArenaMind AI — Environment Variables
# Copy to .env and fill in the values

# ── LLM ──────────────────────────────────────────────────────────────────────
# Required for live LLM responses. Without these the app runs in mock mode.
ANTHROPIC_API_KEY=sk-ant-                    # Claude API key
# OPENAI_API_KEY=sk-...                       # OpenAI API key (alternative)

# ── Database ─────────────────────────────────────────────────────────────────
# These match the docker-compose defaults. Change if using a different setup.
DATABASE_URL=postgresql+asyncpg://arenamind:arenamind@localhost:5432/arenamind
MONGO_URL=mongodb://arenamind:arenamind@localhost:27017/arenamind

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Qdrant (optional) ────────────────────────────────────────────────────────
# Local: http://localhost:6333
# Without this, the app falls back to in-process TF-IDF search (no degradation to user experience)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=stadium_knowledge

# ── Kafka/Redpanda (optional — stretch) ──────────────────────────────────────
REDPANDA_BROKERS=localhost:9092

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=ba8c145278e0107a9f00f6b327036b4f2140643e4a0710309dfec10c4fd68fa3

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development   # development = lenient auth / graceful degradation
DEBUG=true
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Embeddings (optional — TF-IDF is the default) ──────────────────────────────
# EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
# EMBEDDING_DIM=768